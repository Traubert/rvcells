{
  "version": 2,
  "name": "Markov chain",
  "settings": { "numSamples": 10000 },
  "sheets": [
    {
      "name": "Unrolled",
      "cells": {
        "A1": "Employment Markov chain (unrolled, one row per step)",
        "A3": "Month",
        "B3": "Employed? (1=yes)",
        "C3": "Monthly income ($)",
        "A4": "0",
        "B4": "state0 = 1",
        "C4": ":= if(state0, Normal(5000, 500), Normal(1500, 300))",
        "A5": "1",
        "B5": ":= if(B4, Bernoulli(0.95), Bernoulli(0.20))",
        "C5": ":= if(B5, Normal(5000, 500), Normal(1500, 300))",
        "A6": "2",
        "B6": ":= if(B5, Bernoulli(0.95), Bernoulli(0.20))",
        "C6": ":= if(B6, Normal(5000, 500), Normal(1500, 300))",
        "A7": "3",
        "B7": ":= if(B6, Bernoulli(0.95), Bernoulli(0.20))",
        "C7": ":= if(B7, Normal(5000, 500), Normal(1500, 300))",
        "A8": "4",
        "B8": ":= if(B7, Bernoulli(0.95), Bernoulli(0.20))",
        "C8": ":= if(B8, Normal(5000, 500), Normal(1500, 300))",
        "A9": "5",
        "B9": ":= if(B8, Bernoulli(0.95), Bernoulli(0.20))",
        "C9": ":= if(B9, Normal(5000, 500), Normal(1500, 300))",
        "A10": "6",
        "B10": ":= if(B9, Bernoulli(0.95), Bernoulli(0.20))",
        "C10": ":= if(B10, Normal(5000, 500), Normal(1500, 300))",
        "A11": "7",
        "B11": ":= if(B10, Bernoulli(0.95), Bernoulli(0.20))",
        "C11": ":= if(B11, Normal(5000, 500), Normal(1500, 300))",
        "A12": "8",
        "B12": ":= if(B11, Bernoulli(0.95), Bernoulli(0.20))",
        "C12": ":= if(B12, Normal(5000, 500), Normal(1500, 300))",
        "A13": "9",
        "B13": ":= if(B12, Bernoulli(0.95), Bernoulli(0.20))",
        "C13": ":= if(B13, Normal(5000, 500), Normal(1500, 300))",
        "A14": "10",
        "B14": ":= if(B13, Bernoulli(0.95), Bernoulli(0.20))",
        "C14": ":= if(B14, Normal(5000, 500), Normal(1500, 300))",
        "A15": "11",
        "B15": ":= if(B14, Bernoulli(0.95), Bernoulli(0.20))",
        "C15": ":= if(B15, Normal(5000, 500), Normal(1500, 300))",
        "A16": "12",
        "B16": ":= if(B15, Bernoulli(0.95), Bernoulli(0.20))",
        "C16": ":= if(B16, Normal(5000, 500), Normal(1500, 300))",
        "A18": "Total income (12 months)",
        "C18": ":= C4 + C5 + C6 + C7 + C8 + C9 + C10 + C11 + C12 + C13 + C14 + C15 + C16",
        "A19": "Employment rate at month 12",
        "B19": ":= B16"
      }
    },
    {
      "name": "Chain",
      "cells": {
        "A1": "Same model using Chain (one cell per process)",
        "A3": "Transition parameters",
        "A4": "P(keep job)",
        "B4": "pKeep = 0.95",
        "A5": "P(find job)",
        "B5": "pFind = 0.20",
        "A7": "Employment chain",
        "B7": "employed = Chain(if(employed, Bernoulli(pKeep), Bernoulli(pFind)), 1)",
        "A8": "State at month 12",
        "B8": ":= ChainIndex(employed, 12)",
        "A10": "Income chain (synced with employment)",
        "B10": "income = Chain(if(employed, Normal(5000, 500), Normal(1500, 300)), Normal(5000, 500))",
        "A11": "Income at month 12",
        "B11": ":= ChainIndex(income, 12)",
        "A13": "Notes",
        "A14": "The Chain version does the same thing as the Unrolled sheet,",
        "A15": "but in a single cell per process. Click the Chain cells to",
        "A16": "see the Timeline fan chart showing all 12 steps.",
        "A17": "The income chain references the employed chain, so they",
        "A18": "stay synchronized (step 5 of income uses step 5 of employed)."
      }
    }
  ]
}
