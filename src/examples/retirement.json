{
  "version": 2,
  "name": "Retirement savings",
  "settings": { "numSamples": 10000 },
  "sheets": [
    {
      "name": "Fixed age",
      "cells": {
        "A1": "Current age",
        "B1": "age = 35",
        "A2": "Retirement age",
        "B2": "retireAge = 65",
        "A3": "Years to retirement",
        "B3": "years = retireAge - age",
        "A5": "Current savings ($)",
        "B5": "savings = 80000",
        "A6": "Annual contribution ($)",
        "B6": "contrib = Normal(18000, 2000)",
        "A7": "Annual return (%)",
        "B7": "returnPct = Normal(7, 3)",
        "A8": "Inflation (%)",
        "B8": "inflation = Normal(2.5, 0.8)",
        "A9": "Real return (%)",
        "B9": "realReturn := (returnPct - inflation) / 100",
        "A11": "Nest egg at retirement ($)",
        "B11": "nestEgg := Chain(nestEgg * (1 + realReturn) + contrib, savings)",
        "A12": "After planned years",
        "B12": ":= nestEgg[years]",
        "A14": "Annual spending in retirement ($)",
        "B14": "spending = Normal(50000, 8000)",
        "A15": "Years of spending covered",
        "B15": ":= B12 / spending"
      }
    },
    {
      "name": "When ready?",
      "cells": {
        "A1": "When can I retire?",
        "A2": "Uses ChainIndex to find the first year the",
        "A3": "nest egg is large enough to cover retirement.",
        "A5": "Current age",
        "B5": "age = 35",
        "A6": "Current savings ($)",
        "B6": "savings = 80000",
        "A7": "Annual contribution ($)",
        "B7": "contrib = Normal(18000, 2000)",
        "A8": "Real return (%)",
        "B8": "realReturn = Normal(4.5, 2.5) / 100",
        "A10": "Nest egg growth",
        "B10": "nestEgg := Chain(nestEgg * (1 + realReturn) + contrib, savings)",
        "A12": "Annual spending ($)",
        "B12": "spending = Normal(50000, 8000)",
        "A13": "Years of spending to cover",
        "B13": "coverYears = 30",
        "A14": "Target nest egg ($)",
        "B14": "target := coverYears * mean(spending)",
        "A16": "Retire when P25 exceeds target",
        "B16": "yearsNeeded := ChainIndex(nestEgg, P(nestEgg, 25) > target)",
        "A17": "Retirement age",
        "B17": "retireAge := age + yearsNeeded",
        "A18": "Nest egg at retirement ($)",
        "B18": ":= nestEgg[yearsNeeded]"
      }
    }
  ]
}
